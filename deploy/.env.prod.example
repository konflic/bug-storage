# Copy to deploy/.env.prod and fill in. Do NOT commit the real file.
#
#   cp deploy/.env.prod.example deploy/.env.prod
#   make gen-key            # prints a strong key to paste into API_KEY below
#
# NOTE: deploy/.env.prod is git-ignored.

# Public domain that points (A record) at the VM's public IP.
DOMAIN=bugs.example.com

# Email for Let's Encrypt expiry notices.
ACME_EMAIL=you@example.com

# Shared-secret API key. Generate with: make gen-key
API_KEY=

# Dedupe strictness (optional).
SIMILARITY_THRESHOLD=0.45

# --- Only needed if you switch to Postgres in docker-compose.prod.yml ---
# POSTGRES_PASSWORD=change-me
