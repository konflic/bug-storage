# Copy to .env to override defaults.

# SQLite (default, dev):
DATABASE_URL=sqlite:///./data/bugs.db

# Postgres (prod):
# DATABASE_URL=postgresql+psycopg://bugs:bugs@db:5432/bugs

# Dedupe sensitivity (0..1). Higher = stricter (fewer matches).
SIMILARITY_THRESHOLD=0.45
SIMILARITY_LIMIT=10

# --- Authorization (two roles) ---
# ADMIN key: full access (read + all writes + admin endpoints).
# Leave empty to DISABLE auth entirely (dev only).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=
# READ-ONLY key: GET only; safe to embed in a shared URL (?key=...).
# This SEEDS the DB value on first boot; rotate later via the API/UI or
#   POST /admin/rotate-readonly-key.
READONLY_API_KEY=
# Legacy single-key var: if ADMIN_API_KEY is empty, this is used as the admin key.
# API_KEY=
# Paths that stay open (no key). Defaults cover health probes + UI + docs.
# AUTH_OPEN_PATHS=/health,/ui,/,/docs,/redoc,/openapi.json,/favicon.ico
